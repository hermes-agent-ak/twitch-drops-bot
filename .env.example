# Twitch Drops Telegram Bot — Environment Variables
# 
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Get your bot token from @BotFather (use /newbot — do NOT reuse an existing bot)
# 3. Paste the token below:
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Admin chat ID for health alerts
# Get your chat ID by sending /start to @userinfobot on Telegram
ADMIN_CHAT_ID=

# Polling interval in minutes (default: 15)
POLL_INTERVAL_MINUTES=15
